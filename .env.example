# ─────────────────────────────────────────────────────────
# MMW Reporting Engine — environment variable schema
# Copy to .env for local dev. Set all of these in Render.
# Never commit .env — it is in .gitignore.
# ─────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Session ──────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=

# ── Encryption (AES-256-GCM) ─────────────────────────────
# 64 hex characters = 32 bytes
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ── Supabase ─────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Google OAuth (shared medicalmarketingwhiz@gmail.com account) ─
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match exactly what is registered in Google Cloud Console
GOOGLE_REDIRECT_URI=https://your-render-url.onrender.com/auth/google/callback

# ── Existing Marketing Analysis Tool keys ────────────────
GOOGLE_API_KEY=
ADVICE_LOCAL_API_KEY=
ANTHROPIC_API_KEY=
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
